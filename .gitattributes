# Normalize text by default and make common binary payloads explicit.
* text=auto

# Windows-native scripts and solutions
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.vcproj text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.rc text eol=crlf
*.rh text eol=crlf

# Source and config files that are easier to keep LF-normalized
*.cs text eol=lf
*.csproj text eol=lf
*.fs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.patch text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.ftl text eol=lf

# Binary artifacts and assets
*.7z binary
*.bmp binary
*.cur binary
*.dat binary
*.dll binary
*.exe binary
*.gif binary
*.ico binary
*.jar binary
*.jpeg binary
*.jpg binary
*.lib binary
*.mix binary
*.mp3 binary
*.ogg binary
*.otf binary
*.pak binary
*.pdf binary
*.png binary
*.resx binary
*.so binary
*.ttf binary
*.vqa binary
*.wad binary
*.wav binary
*.webp binary
*.zip binary
